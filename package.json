{
  "name": "chromonym",
  "version": "3.4.0",
  "description": "One color-naming API for any palette. Identify, resolve, and convert colors across your own palette or twelve built-in sets (CSS, X11, Pantone, Crayola, NTC, XKCD, Resene, NCS, ISCC-NBS, NBS, FS 595 B/C); fully typed, tree-shakeable, perceptual distance metrics (CIEDE2000 / OKLAB).",
  "keywords": [
    "color",
    "color-name",
    "color-naming",
    "color-identify",
    "color-resolve",
    "color-convert",
    "nearest-color",
    "css-colors",
    "x11-colors",
    "pantone",
    "crayola",
    "deltaE",
    "ciede2000",
    "lab",
    "oklab",
    "perceptual",
    "typescript",
    "tree-shakeable",
    "tree-shaking",
    "hex",
    "rgb",
    "hsl",
    "hsv",
    "palette"
  ],
  "author": "the-simian <info@simiancraft.com>",
  "license": "MIT",
  "homepage": "https://github.com/simiancraft/chromonym#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simiancraft/chromonym.git"
  },
  "bugs": {
    "url": "https://github.com/simiancraft/chromonym/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/palettes/web.d.ts",
      "import": "./dist/palettes/web.js",
      "default": "./dist/palettes/web.js"
    },
    "./x11": {
      "types": "./dist/palettes/x11.d.ts",
      "import": "./dist/palettes/x11.js",
      "default": "./dist/palettes/x11.js"
    },
    "./pantone": {
      "types": "./dist/palettes/pantone.d.ts",
      "import": "./dist/palettes/pantone.js",
      "default": "./dist/palettes/pantone.js"
    },
    "./pokemon": {
      "types": "./dist/palettes/pokemon.d.ts",
      "import": "./dist/palettes/pokemon.js",
      "default": "./dist/palettes/pokemon.js"
    },
    "./resene": {
      "types": "./dist/palettes/resene.d.ts",
      "import": "./dist/palettes/resene.js",
      "default": "./dist/palettes/resene.js"
    },
    "./tailwind": {
      "types": "./dist/palettes/tailwind.d.ts",
      "import": "./dist/palettes/tailwind.js",
      "default": "./dist/palettes/tailwind.js"
    },
    "./crayola": {
      "types": "./dist/palettes/crayola.d.ts",
      "import": "./dist/palettes/crayola.js",
      "default": "./dist/palettes/crayola.js"
    },
    "./fs595b": {
      "types": "./dist/palettes/fs595b.d.ts",
      "import": "./dist/palettes/fs595b.js",
      "default": "./dist/palettes/fs595b.js"
    },
    "./fs595c": {
      "types": "./dist/palettes/fs595c.d.ts",
      "import": "./dist/palettes/fs595c.js",
      "default": "./dist/palettes/fs595c.js"
    },
    "./iscc-nbs": {
      "types": "./dist/palettes/isccNbs.d.ts",
      "import": "./dist/palettes/isccNbs.js",
      "default": "./dist/palettes/isccNbs.js"
    },
    "./nbs": {
      "types": "./dist/palettes/nbs.d.ts",
      "import": "./dist/palettes/nbs.js",
      "default": "./dist/palettes/nbs.js"
    },
    "./ncs": {
      "types": "./dist/palettes/ncs.d.ts",
      "import": "./dist/palettes/ncs.js",
      "default": "./dist/palettes/ncs.js"
    },
    "./ntc": {
      "types": "./dist/palettes/ntc.d.ts",
      "import": "./dist/palettes/ntc.js",
      "default": "./dist/palettes/ntc.js"
    },
    "./werner": {
      "types": "./dist/palettes/werner.d.ts",
      "import": "./dist/palettes/werner.js",
      "default": "./dist/palettes/werner.js"
    },
    "./xkcd": {
      "types": "./dist/palettes/xkcd.d.ts",
      "import": "./dist/palettes/xkcd.js",
      "default": "./dist/palettes/xkcd.js"
    },
    "./conversions/hex": {
      "types": "./dist/conversions/hex.d.ts",
      "import": "./dist/conversions/hex.js",
      "default": "./dist/conversions/hex.js"
    },
    "./conversions/rgb": {
      "types": "./dist/conversions/rgb.d.ts",
      "import": "./dist/conversions/rgb.js",
      "default": "./dist/conversions/rgb.js"
    },
    "./conversions/hsl": {
      "types": "./dist/conversions/hsl.d.ts",
      "import": "./dist/conversions/hsl.js",
      "default": "./dist/conversions/hsl.js"
    },
    "./conversions/hsv": {
      "types": "./dist/conversions/hsv.d.ts",
      "import": "./dist/conversions/hsv.js",
      "default": "./dist/conversions/hsv.js"
    },
    "./conversions/pantone": {
      "types": "./dist/conversions/pantone.d.ts",
      "import": "./dist/conversions/pantone.js",
      "default": "./dist/conversions/pantone.js"
    },
    "./math/deltaE": {
      "types": "./dist/math/deltaE.d.ts",
      "import": "./dist/math/deltaE.js",
      "default": "./dist/math/deltaE.js"
    },
    "./math/colorSpace": {
      "types": "./dist/math/colorSpace.d.ts",
      "import": "./dist/math/colorSpace.js",
      "default": "./dist/math/colorSpace.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsgo",
    "typecheck": "tsgo --noEmit",
    "typecheck:test": "tsgo --noEmit --project tsconfig.test.json",
    "typecheck:demo": "cd demo && bunx tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "check:eslint": "cd demo && bun run lint:eslint",
    "format": "biome format --write .",
    "test": "bun test",
    "check": "bun run lint:fix && bun run check:eslint && bun run typecheck && bun run typecheck:demo && bun run build && bun run typecheck:test && bun run test && (cd demo && bun run build) && bun run check:knip && bun run check:package",
    "check:package": "publint && attw --pack --profile esm-only",
    "check:knip": "knip",
    "demo": "bun run build && cd demo && bun run dev",
    "prepublishOnly": "bun run build && bun run check:package"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.15",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "^1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "fast-check": "^4.8.0",
    "knip": "^6.13.1",
    "publint": "^0.3.20",
    "semantic-release": "^25.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  }
}
