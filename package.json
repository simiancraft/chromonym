{
  "name": "chromonym",
  "version": "2.0.0",
  "description": "One color-naming API for any palette. Identify, resolve, and convert colors across your own palette or the built-in CSS, X11, and Pantone sets — fully typed, tree-shakeable, perceptual distance metrics (CIEDE2000).",
  "keywords": [
    "color",
    "color-name",
    "color-naming",
    "color-identify",
    "color-resolve",
    "color-convert",
    "nearest-color",
    "css-colors",
    "x11-colors",
    "pantone",
    "deltaE",
    "ciede2000",
    "lab",
    "oklab",
    "perceptual",
    "typescript",
    "tree-shakeable",
    "tree-shaking",
    "hex",
    "rgb",
    "hsl",
    "hsv",
    "palette",
    "chromonym"
  ],
  "author": "the-simian <harlinjesse@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/simiancraft/chromonym#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simiancraft/chromonym.git"
  },
  "bugs": {
    "url": "https://github.com/simiancraft/chromonym/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/palettes/web.d.ts",
      "import": "./dist/palettes/web.js",
      "default": "./dist/palettes/web.js"
    },
    "./x11": {
      "types": "./dist/palettes/x11.d.ts",
      "import": "./dist/palettes/x11.js",
      "default": "./dist/palettes/x11.js"
    },
    "./pantone": {
      "types": "./dist/palettes/pantone.d.ts",
      "import": "./dist/palettes/pantone.js",
      "default": "./dist/palettes/pantone.js"
    },
    "./conversions/hex": {
      "types": "./dist/conversions/hex.d.ts",
      "import": "./dist/conversions/hex.js",
      "default": "./dist/conversions/hex.js"
    },
    "./conversions/rgb": {
      "types": "./dist/conversions/rgb.d.ts",
      "import": "./dist/conversions/rgb.js",
      "default": "./dist/conversions/rgb.js"
    },
    "./conversions/hsl": {
      "types": "./dist/conversions/hsl.d.ts",
      "import": "./dist/conversions/hsl.js",
      "default": "./dist/conversions/hsl.js"
    },
    "./conversions/hsv": {
      "types": "./dist/conversions/hsv.d.ts",
      "import": "./dist/conversions/hsv.js",
      "default": "./dist/conversions/hsv.js"
    },
    "./conversions/pantone": {
      "types": "./dist/conversions/pantone.d.ts",
      "import": "./dist/conversions/pantone.js",
      "default": "./dist/conversions/pantone.js"
    },
    "./math/deltaE": {
      "types": "./dist/math/deltaE.d.ts",
      "import": "./dist/math/deltaE.js",
      "default": "./dist/math/deltaE.js"
    },
    "./math/colorSpace": {
      "types": "./dist/math/colorSpace.d.ts",
      "import": "./dist/math/colorSpace.js",
      "default": "./dist/math/colorSpace.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsgo",
    "typecheck": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write .",
    "test": "bun test",
    "demo": "bun run build && cd demo && bun run dev",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "semantic-release": "^25.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  }
}
